{
	"name": "padmonk",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Keyboard & Mouse for xCloud — Xbox controller emulation via the Gamepad API.",
	"scripts": {
		"i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
		"dev": "vite",
		"build": "vite build",
		"prebuild": "npm run i18n",
		"typecheck": "npm run i18n && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.json",
		"test": "vitest run",
		"pretest": "npm run i18n",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"zip": "npm run build && node scripts/zip.mjs"
	},
	"devDependencies": {
		"@crxjs/vite-plugin": "^2.5.0",
		"@inlang/paraglide-js": "^2.20.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.1.11",
		"@types/chrome": "^0.0.328",
		"@types/node": "^22.19.21",
		"archiver": "^7.0.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.38.0",
		"svelte-check": "^4.3.1",
		"tailwindcss": "^4.1.11",
		"typescript": "^5.9.2",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
